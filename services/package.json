{
  "name": "backend-services",
  "version": "1.0.0",
  "private": true,
  "description": "Backend microservices for Next.js frontend (Express + CORS).",
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --maxWorkers=2 --forceExit",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "security:audit": "npm audit --audit-level=high",
    "security:scan": "npx njsscan .",
    
    
    "dev": "nodemon /services/card-data-services/server/server.js",



    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "start": "node ./card-data-services/server/server.js",
    "railway:deploy": "railway up"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "@tcgdex/sdk": "^2.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "eslint": "^9.10.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.0",
    "supertest": "^7.2.2"
  }
}
